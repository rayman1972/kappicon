[Desktop Entry]
Type=Application
Version=1.5
Name=kAppIcon
GenericName=App Icon Manager
Comment=Change Linux app launcher icons without root
# Match AppStream component (software centers)
# See data/io.github.rayman1972.kappicon.metainfo.xml
Exec=kappicon
Icon=kappicon
Terminal=false
Categories=Utility;Qt;KDE;
Keywords=icon;desktop;theme;customize;app;launcher;plasma;kde;
StartupNotify=true
StartupWMClass=kappicon
X-GNOME-UsesNotifications=false
