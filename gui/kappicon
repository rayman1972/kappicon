# 2. Resolve Icon= value — theme name or converted custom file
APP_CLEAN_NAME=$(basename "$SELECTED_APP" .desktop)
PNG_OUTPUT="$TARGET_DIR/${APP_CLEAN_NAME}.png"
ICON_VALUE=""

# Safe cleanup — only deletes if path is under /tmp, always cd HOME first
safe_cleanup() {
    local dir="$1"
    case "$dir" in
        /tmp/*)
            cd "$HOME" 2>/dev/null || true
            rm -rf "$dir"
            ;;
        *)
            echo "Refusing to remove $dir — not in /tmp" >&2
            ;;
    esac
}

if [[ "$SELECTED_ICON" == theme:* ]]; then
    # System theme icon — write the freedesktop name directly (e.g. plasmadiscover)
    ICON_VALUE="${SELECTED_ICON#theme:}"
    if [ -z "$ICON_VALUE" ]; then
        show_error "Empty theme icon name."
        exit 1
    fi
else
    SELECTED_ICON_PATH="$SELECTED_ICON"
    if [ ! -f "$SELECTED_ICON_PATH" ]; then
        show_error "Icon file not found:\n$SELECTED_ICON_PATH"
        exit 1
    fi

    WORK_DIR=$(mktemp -d)
    cp "$SELECTED_ICON_PATH" "$WORK_DIR/source_file"

    FILE_EXT="${SELECTED_ICON_PATH##*.}"
    FILE_EXT=$(echo "$FILE_EXT" | tr '[:upper:]' '[:lower:]')

    case "$FILE_EXT" in
        icns)
            (cd "$WORK_DIR" && icns2png -x source_file) > /dev/null 2>&1
            EXTRACTED_FILE=$(find "$WORK_DIR" -maxdepth 1 \( -name '*1024x1024*.png' -o -name '*512x512*.png' \) 2>/dev/null | head -n 1)
            if [ -z "$EXTRACTED_FILE" ]; then
                EXTRACTED_FILE=$(ls -S "$WORK_DIR"/*.png 2>/dev/null | head -n 1)
            fi
            if [ -f "$EXTRACTED_FILE" ]; then
                "$MAGICK_CMD" "$EXTRACTED_FILE" -fuzz 10% -trim +repage -resize 512x512 -background none -gravity center -extent 512x512 "$PNG_OUTPUT"
            else
                show_error "Could not extract a valid PNG from this .icns file."
                safe_cleanup "$WORK_DIR"
                exit 1
            fi
            ;;
        png|jpg|jpeg|webp|bmp|gif)
            "$MAGICK_CMD" "$WORK_DIR/source_file" -fuzz 10% -trim +repage -resize 512x512 -background none -gravity center -extent 512x512 "$PNG_OUTPUT" 2>/dev/null
            if [ ! -f "$PNG_OUTPUT" ]; then
                show_error "Could not process this image file (.$FILE_EXT)."
                safe_cleanup "$WORK_DIR"
                exit 1
            fi
            ;;
        *)
            show_error "Unsupported file type: .$FILE_EXT\nUse PNG, JPG, WEBP, or ICNS."
            safe_cleanup "$WORK_DIR"
            exit 1
            ;;
    esac

    safe_cleanup "$WORK_DIR"
    ICON_VALUE="$PNG_OUTPUT"
