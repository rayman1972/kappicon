def scan_icons(folder):
    files = []
    if os.path.isdir(folder):
        try:
            names = os.listdir(folder)
        except OSError:
            return files
        for f in sorted(names):
            path = os.path.join(folder, f)
            if os.path.isfile(path) and os.path.splitext(f)[1].lower() in ICON_EXTENSIONS:
                files.append(path)
    return files

