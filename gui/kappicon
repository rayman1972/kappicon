fi

# Reject control characters / newlines in icon selection
case "$SELECTED_ICON" in
    *$'\n'*|*$'\r'*) show_error "Invalid icon selection (control characters)."; exit 1 ;;
esac

refresh_icon_caches() {
    kbuildsycoca6 2>/dev/null || kbuildsycoca5 2>/dev/null
    update-desktop-database "$HOME/.local/share/applications" 2>/dev/null
    if [ -d "$HOME/.local/share/icons/hicolor" ]; then
        gtk-update-icon-cache -f -t "$HOME/.local/share/icons/hicolor" 2>/dev/null || true
    fi
    for p in "$HOME/.icons" "$HOME/.local/share/icons"; do
        [ -d "$p" ] && gtk-update-icon-cache -f -t "$p" 2>/dev/null
    done
    qdbus org.kde.plasmashell /PlasmaShell org.kde.PlasmaShell.evaluateScript "
        var desktops = desktops();
        for (var i = 0; i < desktops.length; i++) {
            desktops[i].currentConfigGroup = new Array('General');
            desktops[i].reloadConfig();
        }
    " 2>/dev/null || true
}

if [ "$SELECTED_ICON" = "RESET" ]; then
    if ! acquire_apply_lock; then
        exit 1
    fi
    USER_PATH="$HOME/.local/share/applications/$SELECTED_APP"
    if [ -f "$USER_PATH" ]; then
        SYS_PATH=""
        while IFS= read -r d; do
            [ -n "$d" ] || continue
            if [ "$d" != "$HOME/.local/share/applications" ] && [ -f "$d/$SELECTED_APP" ]; then
                SYS_PATH="$d/$SELECTED_APP"
                break
            fi
        done < <(get_desktop_dirs)

        if [ -n "$SYS_PATH" ] && [ -f "$SYS_PATH" ]; then
            # Only read Icon= from the [Desktop Entry] section of the system file
            ORIG_ICON=$(python3 - "$SYS_PATH" <<'PY'
import sys
path = sys.argv[1]
in_entry = False
try:
    with open(path, "r", errors="replace") as f:
        for raw in f:
            line = raw.strip()
            if line.startswith("[") and line.endswith("]"):
                in_entry = line == "[Desktop Entry]"
                continue
            if in_entry and line.startswith("Icon="):
                print(line.split("=", 1)[1])
                raise SystemExit
except SystemExit:
    raise
except OSError:
    pass
PY
)
            if [ -n "$ORIG_ICON" ]; then
                if set_desktop_icon "$USER_PATH" "$ORIG_ICON"; then
                    show_info "Reset $SELECTED_APP icon back to '$ORIG_ICON'"
                else
                    show_error "Failed to reset icon for $SELECTED_APP"
                    exit 1
                fi
            else
                if clear_desktop_icon "$USER_PATH"; then
                    show_info "Removed custom icon from $SELECTED_APP"
                else
                    show_error "Failed to clear icon for $SELECTED_APP"
                    exit 1
                fi
            fi
        else
            if clear_desktop_icon "$USER_PATH"; then
                show_info "Removed custom icon from $SELECTED_APP"
            else
                show_error "Failed to clear icon for $SELECTED_APP"
                exit 1
            fi
        fi
    else
        show_info "No user override for $SELECTED_APP — already using the system icon."
    fi

    refresh_icon_caches
    exit 0
fi

# 2. Resolve Icon= value — theme name or converted custom file
APP_CLEAN_NAME=$(basename -- "$SELECTED_APP" .desktop)
APP_CLEAN_NAME=$(printf '%s' "$APP_CLEAN_NAME" | tr -c 'A-Za-z0-9._+-' '_' | sed 's/^_\+//;s/_\+$//')
[ -n "$APP_CLEAN_NAME" ] || APP_CLEAN_NAME="app"
PNG_OUTPUT="$TARGET_DIR/${APP_CLEAN_NAME}.png"
ICON_VALUE=""

# User shape preference from Settings (no guessing)
ICON_SHAPE=$(python3 -c '
from PyQt6.QtCore import QSettings
s = QSettings("KAppIcon", "KAppIcon")
v = s.value("icons/shape", "as-is")
print(v if v else "as-is")
' 2>/dev/null || echo "as-is")
ICON_SHAPE=$(printf '%s' "$ICON_SHAPE" | tr '[:upper:]' '[:lower:]' | tr -d '[:space:]')
case "$ICON_SHAPE" in
    as-is|square|rounded|circle) ;;
    *) ICON_SHAPE="as-is" ;;
esac

# Rasterize SRC → OUT at 512² with optional mask (square / rounded / circle).
# Writes via a temp file then renames onto OUT (atomic install).
render_icon_png() {
    local src="$1" out="$2" shape="$3"
    local size=512
    local radius=96   # ~19% of size — macOS-like rounded corners
    local half=$((size / 2))
    local tmp staged
    if [ -z "$MAGICK_CMD" ]; then
        echo "ImageMagick is not installed (need magick or convert)." >&2
        return 1
    fi
    tmp=$(mktemp "${TMPDIR:-/tmp}/kappicon-XXXXXX") || return 1
    staged=$(mktemp "${TMPDIR:-/tmp}/kappicon-out-XXXXXX") || { rm -f -- "$tmp"; return 1; }

    # Base: scale onto transparent square — never trim/fuzz (preserves soft edges)
    if ! "$MAGICK_CMD" "$src" -background none -alpha set \
        -resize "${size}x${size}" -gravity center -extent "${size}x${size}" \
        "$tmp" 2>/dev/null; then
        rm -f -- "$tmp" "$staged"
        return 1
    fi

    case "$shape" in
        circle)
            if ! "$MAGICK_CMD" "$tmp" \
                \( +clone -threshold -1 -negate -fill white \
                   -draw "circle ${half},${half} ${half},0" \) \
                -alpha off -compose copy_opacity -composite \
                "$staged" 2>/dev/null; then
                rm -f -- "$tmp" "$staged"
                return 1
            fi
            ;;
        rounded)
            if ! "$MAGICK_CMD" "$tmp" \
                \( -size "${size}x${size}" xc:none -fill white \
                   -draw "roundrectangle 0,0 $((size - 1)),$((size - 1)) ${radius},${radius}" \) \
                -compose DstIn -composite \
                "$staged" 2>/dev/null; then
                rm -f -- "$tmp" "$staged"
                return 1
            fi
            ;;
        square|as-is|*)
            if ! cp -- "$tmp" "$staged"; then
                rm -f -- "$tmp" "$staged"
                return 1
            fi
            ;;
    esac
    rm -f -- "$tmp"
    if [ ! -s "$staged" ]; then
        rm -f -- "$staged"
        return 1
    fi
    mkdir -p -- "$(dirname -- "$out")" || { rm -f -- "$staged"; return 1; }
    if ! atomic_replace "$staged" "$out"; then
        rm -f -- "$staged"
        return 1
    fi
    [ -f "$out" ]
}

# Serialize mutations of shared state (desktop + hicolor + rendered PNG)
if ! acquire_apply_lock; then
    exit 1
fi

if [[ "$SELECTED_ICON" == theme:* ]]; then
    # System theme icon name — always a freedesktop name (shape N/A; theme draws it)
    ICON_VALUE="${SELECTED_ICON#theme:}"
    if [ -z "$ICON_VALUE" ]; then
        show_error "Empty theme icon name."
        exit 1
    fi
    # Theme names must be free of path seps / shell metacharacters
    if [[ "$ICON_VALUE" =~ [[:space:]/\\] ]] || [[ "$ICON_VALUE" == *".."* ]]; then
        show_error "Invalid theme icon name."
        exit 1
    fi
else
    SELECTED_ICON_PATH="$SELECTED_ICON"
    if [ ! -f "$SELECTED_ICON_PATH" ]; then
        show_error "Icon file not found:\n$SELECTED_ICON_PATH"
        exit 1
    fi

    # Resolve symlinks (theme packs often link dark → light variants)
    SELECTED_ICON_PATH=$(readlink -f "$SELECTED_ICON_PATH" 2>/dev/null || printf '%s' "$SELECTED_ICON_PATH")
    if [ ! -f "$SELECTED_ICON_PATH" ]; then
        show_error "Icon file not found after resolving symlink:\n$SELECTED_ICON_PATH"
        exit 1
    fi

    FILE_EXT="${SELECTED_ICON_PATH##*.}"
    FILE_EXT=$(printf '%s' "$FILE_EXT" | tr '[:upper:]' '[:lower:]')

    # As designed + SVG: use original file (Plasma keeps full quality / shape)
    if [ "$ICON_SHAPE" = "as-is" ] && [[ "$FILE_EXT" == svg || "$FILE_EXT" == svgz ]]; then
        ICON_VALUE="$SELECTED_ICON_PATH"
    else
        WORK_DIR=$(mktemp -d) || { show_error "mktemp failed"; exit 1; }
        SOURCE_COPY="$WORK_DIR/source.$FILE_EXT"
        if ! cp -- "$SELECTED_ICON_PATH" "$SOURCE_COPY"; then
            show_error "Failed to copy source icon."
            exit 1
        fi
        RASTER_SRC="$SOURCE_COPY"

        case "$FILE_EXT" in
            icns)
                if ! command -v icns2png &>/dev/null; then
                    show_error "icns2png is not installed (package: libicns / icnsutils)."
                    exit 1
                fi
                (cd "$WORK_DIR" && icns2png -x "source.$FILE_EXT") > /dev/null 2>&1
                EXTRACTED_FILE=$(find "$WORK_DIR" -maxdepth 1 \( -name '*1024x1024*.png' -o -name '*512x512*.png' \) 2>/dev/null | head -n 1)
                if [ -z "$EXTRACTED_FILE" ]; then
                    EXTRACTED_FILE=$(find "$WORK_DIR" -maxdepth 1 -name '*.png' -printf '%s\t%p\n' 2>/dev/null | sort -nr | head -n 1 | cut -f2-)
                fi
                if [ ! -f "$EXTRACTED_FILE" ]; then
                    show_error "Could not extract a valid PNG from this .icns file."
                    exit 1
                fi
                RASTER_SRC="$EXTRACTED_FILE"
                ;;
            png|jpg|jpeg|webp|bmp|gif|xpm|svg|svgz)
                RASTER_SRC="$SOURCE_COPY"
                ;;
            *)
                show_error "Unsupported file type: .$FILE_EXT\nUse PNG, JPG, WEBP, SVG, or ICNS."
                exit 1
                ;;
        esac

        if ! render_icon_png "$RASTER_SRC" "$PNG_OUTPUT" "$ICON_SHAPE"; then
            show_error "Could not process this image (shape: $ICON_SHAPE)."
            exit 1
        fi

        safe_cleanup "$WORK_DIR"
        WORK_DIR=""
        ICON_VALUE="$PNG_OUTPUT"
    fi
fi

# 3. Overwrite user local app config
USER_APP_DIR="$HOME/.local/share/applications"
mkdir -p "$USER_APP_DIR"
APP_PATH=$(find_desktop_path "$SELECTED_APP" || true)

if [ -z "$APP_PATH" ] || [ ! -f "$APP_PATH" ]; then
    show_error "Could not find desktop entry: $SELECTED_APP"
    exit 1
fi

# Backup if enabled — fail closed so changes stay recoverable
if [ "$BACKUP_ENABLED" = "1" ]; then
    if ! backup_desktop_file "$APP_PATH" "$BACKUP_DIR_DEFAULT" >/dev/null; then
        show_error "Backup failed; aborting to avoid an unrecoverable change."
        exit 1
    fi
fi

if [ "$APP_PATH" != "$USER_APP_DIR/$SELECTED_APP" ]; then
    tmp=$(mktemp "$USER_APP_DIR/.kappicon-desktop-XXXXXX") || exit 1
    if ! cp -a -- "$APP_PATH" "$tmp"; then
        rm -f -- "$tmp"
        show_error "Failed to copy desktop entry to user applications."
        exit 1
    fi
    chmod 644 "$tmp" 2>/dev/null || true
    if ! atomic_replace "$tmp" "$USER_APP_DIR/$SELECTED_APP"; then
        rm -f -- "$tmp"
        show_error "Failed to install user desktop entry."
        exit 1
    fi
fi
# Standard desktop file perms (avoids odd launcher edge cases)
chmod 644 "$USER_APP_DIR/$SELECTED_APP" 2>/dev/null || true

# For custom image files, also install into the user hicolor theme and use an
# icon *name* in Icon=. Plasma menus refresh theme icons more reliably than
# absolute paths under ~/Pictures, and only one desktop id is used (no dupes).
if [[ "$SELECTED_ICON" != theme:* && -f "$ICON_VALUE" ]]; then
    ICON_THEME_NAME="kappicon-${APP_CLEAN_NAME}"
    HICOLOR="$HOME/.local/share/icons/hicolor"
    # scalable / large sizes for menus and panels
    if [[ "${ICON_VALUE##*.}" =~ ^(svg|svgz)$ ]]; then
        mkdir -p "$HICOLOR/scalable/apps"
        ext="${ICON_VALUE##*.}"
        staged=$(mktemp "$HICOLOR/scalable/apps/.kappicon-XXXXXX") || exit 1
        if ! cp -- "$ICON_VALUE" "$staged"; then
            rm -f -- "$staged"
            show_error "Failed to install scalable icon."
            exit 1
        fi
        if ! atomic_replace "$staged" "$HICOLOR/scalable/apps/${ICON_THEME_NAME}.${ext}"; then
            rm -f -- "$staged"
            show_error "Failed to install scalable icon."
            exit 1
        fi
    else
        for sz in 512 256 128 64 48; do
            mkdir -p "$HICOLOR/${sz}x${sz}/apps"
            dest="$HICOLOR/${sz}x${sz}/apps/${ICON_THEME_NAME}.png"
            staged=$(mktemp "$HICOLOR/${sz}x${sz}/apps/.kappicon-XXXXXX") || continue
            if [ "$sz" -eq 512 ]; then
                if ! cp -- "$ICON_VALUE" "$staged"; then
                    rm -f -- "$staged"
                    continue
                fi
            else
                if ! "$MAGICK_CMD" "$ICON_VALUE" -background none -resize "${sz}x${sz}" \
                    "$staged" 2>/dev/null; then
                    rm -f -- "$staged"
                    continue
                fi
            fi
            atomic_replace "$staged" "$dest" || rm -f -- "$staged"
        done
        # Ensure at least the 512px asset landed
        if [ ! -f "$HICOLOR/512x512/apps/${ICON_THEME_NAME}.png" ]; then
            show_error "Failed to install icon into the hicolor theme."
            exit 1
        fi
    fi
    ICON_VALUE="$ICON_THEME_NAME"
fi

# Update Icon= only inside [Desktop Entry], atomically
if ! set_desktop_icon "$USER_APP_DIR/$SELECTED_APP" "$ICON_VALUE"; then
    show_error "Failed to update Icon= in $SELECTED_APP"
    exit 1
fi

# Notify user of success using fallback notification functions
if [[ "$SELECTED_ICON" == theme:* ]]; then
    show_info "Set $SELECTED_APP icon to system icon “${SELECTED_ICON#theme:}”"
else
    show_info "Custom icon successfully mapped to $SELECTED_APP"
fi

refresh_icon_caches
