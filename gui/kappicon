    def _filter_apps(self, text):
        q = text.lower()
        for i in range(self.app_list.count()):
            item = self.app_list.item(i)
            hay = item.text().lower()
            desktop = item.data(Qt.ItemDataRole.UserRole) or ""
            hay += " " + str(desktop).lower()
