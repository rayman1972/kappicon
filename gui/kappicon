    def _filter_files(self, text):
        q = text.lower()
        for i in range(self.file_list.count()):
            item = self.file_list.item(i)
            data = item.data(Qt.ItemDataRole.UserRole) or ""
            hay = item.text().lower()
            if isinstance(data, str):
                hay += " " + data.lower()
