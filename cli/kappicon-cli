#!/bin/bash

# ── XDG Base Directory + user dirs ───────────────────────────────────────
# Honor XDG_* so non-default layouts and localized Pictures/Downloads work.
: "${XDG_CONFIG_HOME:=$HOME/.config}"
: "${XDG_DATA_HOME:=$HOME/.local/share}"
: "${XDG_BIN_HOME:=$HOME/.local/bin}"

# Resolve XDG user dir (DOWNLOAD, PICTURES, …). Prefers `xdg-user-dir`, then
# $XDG_CONFIG_HOME/user-dirs.dirs, then $HOME/<EnglishDefault>.
xdg_user_dir() {
    local key="$1" fallback="$2" val="" udf line varname
    if command -v xdg-user-dir >/dev/null 2>&1; then
        val=$(xdg-user-dir "$key" 2>/dev/null || true)
    fi
    if [ -z "$val" ] || [ "$val" = "$HOME" ]; then
        udf="$XDG_CONFIG_HOME/user-dirs.dirs"
        varname="XDG_${key}_DIR"
        if [ -f "$udf" ]; then
            line=$(grep -E "^${varname}=" "$udf" 2>/dev/null | head -n1 || true)
            if [ -n "$line" ]; then
                val=${line#*=}
                val=${val#\"}
                val=${val%\"}
                val=${val//\$HOME/$HOME}
            fi
        fi
    fi
    if [ -n "$val" ] && [ "$val" != "$HOME" ]; then
        printf '%s\n' "$val"
    else
        printf '%s\n' "$fallback"
    fi
}

XDG_DOWNLOAD_DIR=$(xdg_user_dir DOWNLOAD "$HOME/Downloads")
XDG_PICTURES_DIR=$(xdg_user_dir PICTURES "$HOME/Pictures")

# Run host tools when packaged as Flatpak (icon cache / kbuildsycoca).
run_host() {
    if [ -n "${FLATPAK_ID:-}" ] && command -v flatpak-spawn >/dev/null 2>&1; then
        flatpak-spawn --host -- "$@"
    else
        "$@"
    fi
}

# ── Config ───────────────────────────────────────────────────────────────
CONFIG_DIR="${CONFIG_DIR:-$XDG_CONFIG_HOME/KAppIcon}"
CONFIG_FILE="$CONFIG_DIR/KAppIcon.conf"
DATA_DIR="${DATA_DIR:-$XDG_DATA_HOME/kappicon}"
BACKUP_DIR="$DATA_DIR/backups"
USER_APPS_DIR="${USER_APPS_DIR:-$XDG_DATA_HOME/applications}"
USER_ICONS_DIR="${USER_ICONS_DIR:-$XDG_DATA_HOME/icons}"
TARGET_DIR="${TARGET_DIR:-$XDG_PICTURES_DIR/KAppIcon}"
LOCK_FILE="$DATA_DIR/apply.lock"
mkdir -p "$TARGET_DIR" "$CONFIG_DIR" "$BACKUP_DIR" "$USER_APPS_DIR"

# Track temp workdirs for EXIT/INT/TERM cleanup (avoids leaks on interrupt)
WORK_DIR=""
cleanup_on_exit() {
    [ -n "${WORK_DIR:-}" ] && safe_cleanup "$WORK_DIR"
    WORK_DIR=""
}
trap cleanup_on_exit EXIT INT TERM HUP

# ── Helpers: path / id validation ────────────────────────────────────────
# Freedesktop desktop ids are basenames; never allow path components.
is_valid_desktop_id() {
    local id="$1"
    [ -n "$id" ] || return 1
    # Reject path separators / traversal / control chars; allow common freeform names
    case "$id" in
        */*|*"\\"*|*".."*|*$'\n'*|*$'\r'*|.*|"") return 1 ;;
    esac
    [[ "$id" == *.desktop ]] || return 1
    # basename must equal the whole id (no directories)
    [ "$(basename -- "$id")" = "$id" ] || return 1
    # Non-empty stem before .desktop
    [ "${#id}" -gt 8 ] || return 1
    return 0
}

# True if path is under a known temp root (never delete arbitrary paths).
is_temp_path() {
    local p="$1" real base
    [ -n "$p" ] || return 1
    real=$(readlink -f "$p" 2>/dev/null || printf '%s' "$p")
    [ -n "$real" ] || return 1
    # Refuse empty or filesystem root
    [ "$real" = "/" ] && return 1
    for base in /tmp /var/tmp "${TMPDIR:-}" "${XDG_RUNTIME_DIR:-}"; do
        [ -n "$base" ] || continue
        base=$(readlink -f "$base" 2>/dev/null || printf '%s' "$base")
        [ -n "$base" ] && [ "$base" != "/" ] || continue
        case "$real" in
            "$base"/*) return 0 ;;
        esac
    done
    return 1
}

safe_cleanup() {
    local dir="$1"
    [ -n "$dir" ] || return 0
    if is_temp_path "$dir"; then
        cd "$HOME" 2>/dev/null || cd / 2>/dev/null || true
        rm -rf -- "$dir"
    else
        echo "Refusing to remove $dir — not under a temp directory" >&2
    fi
}

# Serialize apply/restore against concurrent CLI+GUI instances (race on
# same .desktop / same PNG / same backup second).
acquire_apply_lock() {
    mkdir -p "$DATA_DIR"
    # FD 9 held for the rest of this process
    exec 9>"$LOCK_FILE" || return 1
    if ! command -v flock &>/dev/null; then
        echo "❌ flock is required for safe apply (install util-linux)." >&2
        return 1
    fi
    if ! flock -w 45 9; then
        echo "❌ Another kAppIcon operation is in progress (lock timeout)." >&2
        return 1
    fi
    return 0
}

# Atomic rename when possible (same filesystem).
atomic_replace() {
    local src="$1" dest="$2"
    mv -f -- "$src" "$dest"
}

# Unique backup path: timestamp + pid + random (no second-collision clobber).
backup_desktop_file() {
    local src="$1"
    local base dest
    [ -f "$src" ] || return 1
    mkdir -p "$BACKUP_DIR" || return 1
    base=$(basename -- "$src")
    if ! is_valid_desktop_id "$base"; then
        echo "❌ Refusing to backup invalid desktop id: $base" >&2
        return 1
    fi
    dest="$BACKUP_DIR/${base}.backup.$(date +%Y%m%d%H%M%S).$$.$RANDOM"
    while [ -e "$dest" ]; do
        dest="$BACKUP_DIR/${base}.backup.$(date +%Y%m%d%H%M%S).$$.$RANDOM"
    done
    cp -a -- "$src" "$dest" || return 1
    printf '%s\n' "$dest"
}

# Set Icon= only inside [Desktop Entry] (never Action sections), atomically.
set_desktop_icon() {
    local desktop_file="$1" icon_value="$2"
    python3 - "$desktop_file" "$icon_value" <<'PY'
import os, sys, tempfile

path, icon = sys.argv[1], sys.argv[2]
if not path or not icon:
    sys.exit("empty path or icon")
if os.path.sep in os.path.basename(path) or path.endswith(os.path.sep):
    sys.exit("invalid desktop path")

try:
    with open(path, "r", errors="replace") as f:
        lines = f.readlines()
except OSError as e:
    print(e, file=sys.stderr)
    sys.exit(1)

out = []
in_entry = False
icon_set = False
for line in lines:
    stripped = line.strip()
    if stripped.startswith("[") and stripped.endswith("]"):
        # Leaving Desktop Entry without Icon= — append before next section
        if in_entry and not icon_set:
            out.append(f"Icon={icon}\n")
            icon_set = True
        in_entry = stripped == "[Desktop Entry]"
        out.append(line if line.endswith("\n") else line + "\n")
        continue
    if in_entry and stripped.startswith("Icon="):
        if not icon_set:
            out.append(f"Icon={icon}\n")
            icon_set = True
        # Drop duplicate Icon= lines in the same section
        continue
    out.append(line if line.endswith("\n") or line == "" else line + "\n")

if in_entry and not icon_set:
    out.append(f"Icon={icon}\n")
elif not icon_set:
    # No [Desktop Entry] at all — prepend a minimal one
    out.insert(0, "[Desktop Entry]\n")
    out.insert(1, f"Icon={icon}\n")

dirn = os.path.dirname(path) or "."
fd, tmp = tempfile.mkstemp(prefix=".kappicon-", suffix=".desktop", dir=dirn)
try:
    with os.fdopen(fd, "w") as f:
        f.writelines(out)
        f.flush()
        try:
            os.fsync(f.fileno())
        except OSError:
            pass
    os.chmod(tmp, 0o644)
    os.replace(tmp, path)
except Exception:
    try:
        os.unlink(tmp)
    except OSError:
        pass
    raise
PY
}

# Remove Icon= only from [Desktop Entry], atomically.
clear_desktop_icon() {
    local desktop_file="$1"
    python3 - "$desktop_file" <<'PY'
import os, sys, tempfile

path = sys.argv[1]
try:
    with open(path, "r", errors="replace") as f:
        lines = f.readlines()
except OSError as e:
    print(e, file=sys.stderr)
    sys.exit(1)

out = []
in_entry = False
for line in lines:
    stripped = line.strip()
    if stripped.startswith("[") and stripped.endswith("]"):
        in_entry = stripped == "[Desktop Entry]"
        out.append(line if line.endswith("\n") else line + "\n")
        continue
    if in_entry and stripped.startswith("Icon="):
        continue
    out.append(line if line.endswith("\n") or line == "" else line + "\n")

dirn = os.path.dirname(path) or "."
fd, tmp = tempfile.mkstemp(prefix=".kappicon-", suffix=".desktop", dir=dirn)
try:
    with os.fdopen(fd, "w") as f:
        f.writelines(out)
        f.flush()
        try:
            os.fsync(f.fileno())
        except OSError:
            pass
    os.chmod(tmp, 0o644)
    os.replace(tmp, path)
except Exception:
    try:
        os.unlink(tmp)
    except OSError:
        pass
    raise
PY
}

# Resolve desktop id → full path (user override wins).
find_desktop_path() {
    local id="$1" d
    local user_dir="$USER_APPS_DIR"
    if [ -f "$user_dir/$id" ]; then
        printf '%s\n' "$user_dir/$id"
        return 0
    fi
    while IFS= read -r d; do
        [ -n "$d" ] || continue
        if [ -f "$d/$id" ]; then
            printf '%s\n' "$d/$id"
            return 0
        fi
    done < <(get_desktop_dirs)
    return 1
}

# Read/write config (QSettings INI: key "source/folder" → [source] folder=...)
cfg_get() {
    local key="$1" default="$2"
    local section="${key%%/*}"
    local option="${key#*/}"
    if [ "$section" = "$key" ]; then
        section="General"
        option="$key"
    fi
    if [ ! -f "$CONFIG_FILE" ]; then
        echo "$default"
        return
    fi
    local val
    val=$(python3 - "$CONFIG_FILE" "$section" "$option" "$default" <<'PY'
import sys
from configparser import ConfigParser
path, section, option, default = sys.argv[1:5]
cp = ConfigParser()
cp.optionxform = str  # preserve case
try:
    cp.read(path)
except Exception:
    print(default)
    raise SystemExit
if cp.has_option(section, option):
    print(cp.get(section, option))
elif section != "General" and cp.has_option("General", f"{section}/{option}"):
    # legacy flat key written as source/folder=...
    print(cp.get("General", f"{section}/{option}"))
else:
    # legacy flat file without sections: source/folder=value
    try:
        with open(path, "r", errors="replace") as f:
            for line in f:
                line = line.strip()
                if line.startswith(f"{section}/{option}=") or line.startswith(f"{option}="):
                    print(line.split("=", 1)[1])
                    raise SystemExit
    except SystemExit:
        raise
    except Exception:
        pass
    print(default)
PY
)
    echo "${val:-$default}"
}

cfg_set() {
    local key="$1" val="$2"
    local section="${key%%/*}"
    local option="${key#*/}"
    if [ "$section" = "$key" ]; then
        section="General"
        option="$key"
    fi
    mkdir -p "$CONFIG_DIR"
    # Atomic write: temp sibling + os.replace (survives concurrent readers; no truncate race)
    python3 - "$CONFIG_FILE" "$section" "$option" "$val" <<'PY'
import os, sys, tempfile
from configparser import ConfigParser

path, section, option, val = sys.argv[1:5]
cp = ConfigParser()
cp.optionxform = str
if os.path.isfile(path):
    try:
        cp.read(path)
    except Exception:
        pass
if not cp.has_section(section):
    cp.add_section(section)
cp.set(section, option, val)

dirn = os.path.dirname(path) or "."
os.makedirs(dirn, exist_ok=True)
fd, tmp = tempfile.mkstemp(prefix=".KAppIcon.conf.", dir=dirn)
try:
    with os.fdopen(fd, "w") as f:
        cp.write(f)
        f.flush()
        try:
            os.fsync(f.fileno())
        except OSError:
            pass
    os.replace(tmp, path)
except Exception:
    try:
        os.unlink(tmp)
    except OSError:
        pass
    raise
PY
}

DOWNLOADS_DIR=$(cfg_get "source/folder" "$XDG_DOWNLOAD_DIR")
BACKUP_ENABLED=$(cfg_get "backups/enabled" "false")

# Help / lightweight flags must work without mapper-only dependencies (fzf, ImageMagick)
case "${1:-}" in
    --help|-h)
        echo "Usage: kappicon-cli [OPTION]"
        echo ""
        echo "Options:"
        echo "  (none)       Launch the interactive icon mapper (needs fzf + ImageMagick)"
        echo "  --settings   Configure source folder, backups, etc."
        echo "  --restore    Restore a .desktop file from backup"
        echo "  --refresh    Force refresh icon caches"
        echo "  --help       Show this help"
        exit 0
        ;;
esac

# ── Helpers: desktop file locations ──────────────────────────────────────
get_desktop_dirs() {
    local dirs=()
    local xdg_dirs="${XDG_DATA_DIRS:-/usr/local/share:/usr/share}"
    local d
    local -a split_dirs=()
    IFS=':' read -r -a split_dirs <<< "$xdg_dirs"
    # User data home first (overrides), then XDG_DATA_DIRS system roots
    for d in "$XDG_DATA_HOME" "${split_dirs[@]}"; do
        [ -n "$d" ] || continue
        [ -d "$d/applications" ] && dirs+=("$d/applications")
    done
    # Flatpak sandbox: host OS trees appear under /run/host
    if [ -n "${FLATPAK_ID:-}" ]; then
        for d in /run/host/usr/share /run/host/usr/local/share; do
            [ -d "$d/applications" ] && dirs+=("$d/applications")
        done
    fi
    # Flatpak exports (system + user; user may live under XDG_DATA_HOME)
    [ -d "/var/lib/flatpak/exports/share/applications" ] && dirs+=("/var/lib/flatpak/exports/share/applications")
    [ -d "$XDG_DATA_HOME/flatpak/exports/share/applications" ] && dirs+=("$XDG_DATA_HOME/flatpak/exports/share/applications")
    if [ "$XDG_DATA_HOME" != "$HOME/.local/share" ]; then
        [ -d "$HOME/.local/share/flatpak/exports/share/applications" ] && \
            dirs+=("$HOME/.local/share/flatpak/exports/share/applications")
        [ -d "$HOME/.local/share/applications" ] && dirs+=("$HOME/.local/share/applications")
    fi
    # Snap
    [ -d "/var/lib/snapd/desktop/applications" ] && dirs+=("/var/lib/snapd/desktop/applications")
    [ -d "/run/host/var/lib/snapd/desktop/applications" ] && dirs+=("/run/host/var/lib/snapd/desktop/applications")

    printf "%s\n" "${dirs[@]}" | sort -u
}

# Null-safe iteration: never word-split directory paths that contain spaces.
find_desktop_files() {
    local d
    while IFS= read -r d; do
        [ -n "$d" ] && [ -d "$d" ] || continue
        find "$d" -name "*.desktop" 2>/dev/null
    done < <(get_desktop_dirs)
}

# Lines: "App Name [id.desktop]" — trailing bracket only (names may contain []).
list_apps_for_picker() {
    local desk name base
    while IFS= read -r desk; do
        [ -f "$desk" ] || continue
        base=$(basename -- "$desk")
        is_valid_desktop_id "$base" || continue
        name=$(grep -m 1 -E '^Name=' "$desk" 2>/dev/null | head -n 1 | cut -d= -f2-)
        [ -n "$name" ] || name="$base"
        # Single-line only (desktop Name= must not carry raw newlines in practice)
        name=${name//$'\n'/ }
        name=${name//$'\r'/}
        printf '%s [%s]\n' "$name" "$base"
    done < <(find_desktop_files) | sort -u
}

# ── Helper: force icon refresh ───────────────────────────────────────────
do_refresh() {
    echo "🔄 Refreshing icon caches..."
    run_host kbuildsycoca6 --noincremental 2>/dev/null \
        || run_host kbuildsycoca6 2>/dev/null \
        || run_host kbuildsycoca5 --noincremental 2>/dev/null \
        || run_host kbuildsycoca5 2>/dev/null \
        || true
    run_host update-desktop-database "$USER_APPS_DIR" 2>/dev/null || true
    if [ -d "$USER_ICONS_DIR/hicolor" ]; then
        run_host gtk-update-icon-cache -f -t "$USER_ICONS_DIR/hicolor" 2>/dev/null || true
    fi
    for p in "$HOME/.icons" "$USER_ICONS_DIR"; do
        [ -d "$p" ] && run_host gtk-update-icon-cache -f -t "$p" 2>/dev/null || true
    done
    echo "✅ Icon caches refreshed."
}

# ── Helper: list backups ─────────────────────────────────────────────────
do_restore() {
    if [ ! -d "$BACKUP_DIR" ]; then
        echo "❌ No backups directory found."
        exit 1
    fi
    mapfile -t backups < <(find "$BACKUP_DIR" -maxdepth 1 -name "*.backup.*" -printf "%f\n" 2>/dev/null | sort -r)
    if [ ${#backups[@]} -eq 0 ]; then
        echo "❌ No backups found in $BACKUP_DIR"
        exit 1
    fi
    echo "📋 Available backups:"
    selected=$(printf '%s\n' "${backups[@]}" | fzf --height 40% --reverse --prompt="Restore > ")
    if [ -z "$selected" ]; then
        echo "Cancelled."
        exit 0
    fi
    # Only allow restore from inside BACKUP_DIR (no path components in selection)
    case "$selected" in
        */*|*".."*) echo "❌ Invalid backup name."; exit 1 ;;
    esac
    # Parse <desktop_id>.backup.<YYYYMMDDHHMMSS>.<pid>.<suffix> (id may contain .backup.)
    desktop_name=$(python3 - "$selected" <<'PY'
import re, sys
name = sys.argv[1]
m = re.match(r"^(.+)\.backup\.(\d{14})\.(\d+)\.([A-Za-z0-9]+)$", name)
print(m.group(1) if m else "")
PY
)
    if ! is_valid_desktop_id "$desktop_name"; then
        echo "❌ Backup does not map to a valid desktop id: ${desktop_name:-$selected}"
        exit 1
    fi
    src="$BACKUP_DIR/$selected"
    dest="$USER_APPS_DIR/$desktop_name"
    if [ ! -f "$src" ]; then
        echo "❌ Backup file missing: $src"
        exit 1
    fi
    # Guard: resolved path must stay under BACKUP_DIR
    src_real=$(readlink -f "$src" 2>/dev/null || printf '%s' "$src")
    backup_real=$(readlink -f "$BACKUP_DIR" 2>/dev/null || printf '%s' "$BACKUP_DIR")
    case "$src_real" in
        "$backup_real"/*) ;;
        *) echo "❌ Backup path escaped backup directory."; exit 1 ;;
    esac

    if ! acquire_apply_lock; then
        exit 1
    fi
    mkdir -p "$USER_APPS_DIR"
    tmp=$(mktemp "$USER_APPS_DIR/.kappicon-restore-XXXXXX") || exit 1
    if ! cp -a -- "$src" "$tmp"; then
        rm -f -- "$tmp"
        echo "❌ Failed to copy backup."
        exit 1
    fi
    chmod 644 "$tmp" 2>/dev/null || true
    if ! atomic_replace "$tmp" "$dest"; then
        rm -f -- "$tmp"
        echo "❌ Failed to install restored desktop file."
        exit 1
    fi
    echo "✅ Restored $desktop_name from backup."
    do_refresh
}

# ── Helper: interactive settings ─────────────────────────────────────────
do_settings() {
    echo ""
    echo "═══ kAppIcon Settings ═══"
    echo ""
    echo "  1) Source Folder    : $DOWNLOADS_DIR"
    echo "  2) Auto Backups     : $BACKUP_ENABLED"
    echo "  3) Force Refresh"
    echo "  4) Restore Backup"
    echo "  5) Done"
    echo ""
    read -rp "  Choose [1-5]: " choice
    case "$choice" in
        1)
            read -rp "  Enter new source folder: " new_path
            # Expand ~ if user typed it
            new_path="${new_path/#\~/$HOME}"
            if [ -d "$new_path" ]; then
                cfg_set "source/folder" "$new_path"
                DOWNLOADS_DIR="$new_path"
                echo "  ✅ Source folder updated."
            else
                echo "  ❌ Directory does not exist."
            fi
            do_settings
            ;;
        2)
            if [ "$BACKUP_ENABLED" = "true" ]; then
                cfg_set "backups/enabled" "false"
                BACKUP_ENABLED="false"
                echo "  ✅ Automatic backups disabled."
            else
                cfg_set "backups/enabled" "true"
                BACKUP_ENABLED="true"
                echo "  ✅ Automatic backups enabled."
            fi
            do_settings
            ;;
        3) do_refresh; do_settings ;;
        4) do_restore; do_settings ;;
        5) echo "Done." ;;
        *) echo "  Invalid choice."; do_settings ;;
    esac
}

# ── Parse flags ──────────────────────────────────────────────────────────
case "${1:-}" in
    --settings)  do_settings; exit 0 ;;
    --restore)   do_restore; exit 0 ;;
    --refresh)   do_refresh; exit 0 ;;
esac

# ── Main: interactive icon mapper (needs fzf + ImageMagick) ──────────────
if ! command -v fzf &>/dev/null; then
    echo "❌ fzf is not installed. Please install it first (or run the GUI: kappicon)." >&2
    exit 1
fi

MAGICK_CMD="magick"
if ! command -v magick &>/dev/null; then
    if command -v convert &>/dev/null; then
        MAGICK_CMD="convert"
    else
        echo "❌ ImageMagick is not installed. Please install it (magick or convert)." >&2
        exit 1
    fi
fi

if [ ! -d "$DOWNLOADS_DIR" ]; then
    echo "❌ Source folder not found: $DOWNLOADS_DIR"
    echo "   Run: kappicon-cli --settings   (option 1) to set a different folder."
    exit 1
fi
cd "$DOWNLOADS_DIR" || { echo "❌ Cannot enter source folder: $DOWNLOADS_DIR"; exit 1; }
# Support common icon/image formats (case-insensitive)
mapfile -t ICNS_FILES < <(find . -maxdepth 1 -type f \( \
    -iname '*.icns' -o -iname '*.png' -o -iname '*.jpg' -o -iname '*.jpeg' \
    -o -iname '*.webp' -o -iname '*.bmp' -o -iname '*.gif' -o -iname '*.svg' \
    -o -iname '*.svgz' -o -iname '*.xpm' \
\) -printf '%f\n' 2>/dev/null | sort)

if [ ${#ICNS_FILES[@]} -eq 0 ]; then
    echo "❌ No icon files found in:"
    echo "   $DOWNLOADS_DIR"
    echo ""
    echo "   Supported: .icns .png .jpg .webp .svg"
    echo "   Or create icons in the GUI:  kappicon  (Create tab)"
    echo "   Or change folder:           kappicon-cli --settings"
    exit 1
fi

echo "Select the icon file you want to use:"
SELECTED_ICNS=$(printf '%s\n' "${ICNS_FILES[@]}" | fzf --height 40% --reverse)

if [ -z "$SELECTED_ICNS" ]; then
    echo "Cancelled."
    exit 0
fi
# Reject path components from fzf selection (should be basename only)
case "$SELECTED_ICNS" in
    */*|*".."*) echo "❌ Invalid icon selection."; exit 1 ;;
esac

echo "🔍 Select the app you want to map this icon to:"
SELECTED_LINE=$(list_apps_for_picker | fzf --height 50% --reverse)

if [ -z "$SELECTED_LINE" ]; then
    echo "Cancelled."
    exit 0
fi

# Extract basename from trailing [id.desktop] only (app Name may contain [])
SELECTED_APP=$(printf '%s\n' "$SELECTED_LINE" | sed -n 's/.*\[\([^][]*\)\]$/\1/p')

if [ -z "$SELECTED_APP" ] || ! is_valid_desktop_id "$SELECTED_APP"; then
    echo "❌ Invalid or missing desktop id in selection."
    exit 1
fi

SRC_PATH="$DOWNLOADS_DIR/$SELECTED_ICNS"
if [ ! -f "$SRC_PATH" ]; then
    echo "❌ Icon file disappeared or is unreadable: $SRC_PATH"
    exit 1
fi
SRC_PATH=$(readlink -f "$SRC_PATH" 2>/dev/null || printf '%s' "$SRC_PATH")
if [ ! -f "$SRC_PATH" ]; then
    echo "❌ Icon file not found after resolving symlink: $SRC_PATH"
    exit 1
fi
FILE_EXT="${SRC_PATH##*.}"
FILE_EXT=$(printf '%s' "$FILE_EXT" | tr '[:upper:]' '[:lower:]')

# Collision-resistant + content-addressed theme name (matches GUI contract)
ICON_THEME_NAME=$(python3 - "$SELECTED_APP" "$SRC_PATH" <<'PY'
import hashlib, re, sys
desktop_id, path = sys.argv[1], sys.argv[2]
base = desktop_id[:-8] if desktop_id.endswith(".desktop") else desktop_id
label = re.sub(r"[^A-Za-z0-9._+-]", "_", base).strip("_")[:48] or "app"
id_hash = hashlib.sha256(desktop_id.encode()).hexdigest()[:10]
h = hashlib.sha256(b"as-is\0" + desktop_id.encode())
with open(path, "rb") as f:
    for chunk in iter(lambda: f.read(65536), b""):
        h.update(chunk)
print(f"kappicon-{label}-{id_hash}-{h.hexdigest()[:12]}")
PY
)
[ -n "$ICON_THEME_NAME" ] || { echo "❌ Failed to compute icon name."; exit 1; }
PNG_OUTPUT="$TARGET_DIR/${ICON_THEME_NAME}.png"
HICOLOR="$USER_ICONS_DIR/hicolor"

# Serialize mutations of shared state
if ! acquire_apply_lock; then
    exit 1
fi

# Render / stage asset, then install into user hicolor (never depend on Downloads path)
case "$FILE_EXT" in
    svg|svgz)
        echo "✅ Installing SVG into user hicolor (scalable)…"
        mkdir -p "$HICOLOR/scalable/apps"
        staged=$(mktemp "$HICOLOR/scalable/apps/.kappicon-XXXXXX") || exit 1
        if ! cp -- "$SRC_PATH" "$staged"; then
            rm -f -- "$staged"
            echo "❌ Failed to install SVG icon."
            exit 1
        fi
        if ! atomic_replace "$staged" "$HICOLOR/scalable/apps/${ICON_THEME_NAME}.${FILE_EXT}"; then
            rm -f -- "$staged"
            echo "❌ Failed to install SVG icon."
            exit 1
        fi
        ICON_VALUE="$ICON_THEME_NAME"
        ;;
    *)
        WORK_DIR=$(mktemp -d) || { echo "❌ mktemp failed"; exit 1; }
        SOURCE_COPY="$WORK_DIR/source.$FILE_EXT"
        if ! cp -- "$SRC_PATH" "$SOURCE_COPY"; then
            echo "❌ Failed to copy source icon."
            exit 1
        fi

        # Render to a temp sibling then rename (no half-written PNG on crash/race)
        mkdir -p "$TARGET_DIR"
        PNG_TMP=$(mktemp "$TARGET_DIR/.kappicon-render-XXXXXX") || exit 1

        case "$FILE_EXT" in
            icns)
                echo "🚀 Extracting image assets safely..."
                if ! command -v icns2png &>/dev/null; then
                    echo "❌ icns2png is not installed (package: libicns / icnsutils)."
                    rm -f -- "$PNG_TMP"
                    exit 1
                fi
                (cd "$WORK_DIR" && icns2png -x "source.$FILE_EXT") > /dev/null 2>&1
                EXTRACTED_FILE=$(find "$WORK_DIR" -maxdepth 1 \( -name '*1024x1024*.png' -o -name '*512x512*.png' \) 2>/dev/null | head -n 1)
                if [ -z "$EXTRACTED_FILE" ]; then
                    EXTRACTED_FILE=$(find "$WORK_DIR" -maxdepth 1 -name '*.png' -printf '%s\t%p\n' 2>/dev/null | sort -nr | head -n 1 | cut -f2-)
                fi
                if [ -f "$EXTRACTED_FILE" ]; then
                    echo "📐 Applying the icon..."
                    # No -fuzz/-trim: those nibble anti-aliased rounded corners
                    if ! "$MAGICK_CMD" "$EXTRACTED_FILE" -background none -alpha set \
                        -resize 512x512 -gravity center -extent 512x512 "$PNG_TMP"; then
                        echo "❌ ImageMagick failed to process extracted PNG."
                        rm -f -- "$PNG_TMP"
                        exit 1
                    fi
                else
                    echo "❌ Extraction failed! Could not extract a valid PNG from this .icns file."
                    rm -f -- "$PNG_TMP"
                    exit 1
                fi
                ;;
            png|jpg|jpeg|webp|bmp|gif|xpm)
                echo "📐 Applying the icon..."
                if ! "$MAGICK_CMD" "$SOURCE_COPY" -background none -alpha set \
                    -resize 512x512 -gravity center -extent 512x512 "$PNG_TMP" 2>/dev/null; then
                    echo "❌ Could not process this image file (.$FILE_EXT)."
                    rm -f -- "$PNG_TMP"
                    exit 1
                fi
                if [ ! -s "$PNG_TMP" ]; then
                    echo "❌ Could not process this image file (.$FILE_EXT)."
                    rm -f -- "$PNG_TMP"
                    exit 1
                fi
                ;;
            *)
                echo "❌ Unsupported file type: .$FILE_EXT (use png/jpg/webp/svg/icns)"
                rm -f -- "$PNG_TMP"
                exit 1
                ;;
        esac

        if ! atomic_replace "$PNG_TMP" "$PNG_OUTPUT"; then
            rm -f -- "$PNG_TMP"
            echo "❌ Failed to install rendered icon."
            exit 1
        fi
        safe_cleanup "$WORK_DIR"
        WORK_DIR=""
        echo "✅ Staged PNG: $PNG_OUTPUT"

        # Install multi-size hicolor (same contract as GUI)
        for sz in 512 256 128 64 48; do
            mkdir -p "$HICOLOR/${sz}x${sz}/apps"
            dest="$HICOLOR/${sz}x${sz}/apps/${ICON_THEME_NAME}.png"
            staged=$(mktemp "$HICOLOR/${sz}x${sz}/apps/.kappicon-XXXXXX") || continue
            if [ "$sz" -eq 512 ]; then
                if ! cp -- "$PNG_OUTPUT" "$staged"; then
                    rm -f -- "$staged"
                    continue
                fi
            else
                if ! "$MAGICK_CMD" "$PNG_OUTPUT" -background none -resize "${sz}x${sz}" \
                    "$staged" 2>/dev/null; then
                    rm -f -- "$staged"
                    continue
                fi
            fi
            atomic_replace "$staged" "$dest" || rm -f -- "$staged"
        done
        if [ ! -f "$HICOLOR/512x512/apps/${ICON_THEME_NAME}.png" ]; then
            echo "❌ Failed to install icon into the hicolor theme."
            exit 1
        fi
        ICON_VALUE="$ICON_THEME_NAME"
        ;;
esac

# Overwrite user local app config — prefer an existing user override if present
USER_APP_DIR="$USER_APPS_DIR"
mkdir -p "$USER_APP_DIR"
APP_PATH=$(find_desktop_path "$SELECTED_APP" || true)

if [ -z "$APP_PATH" ] || [ ! -f "$APP_PATH" ]; then
    echo "❌ Could not find desktop entry: $SELECTED_APP"
    exit 1
fi

# Backup if enabled
if [ "$BACKUP_ENABLED" = "true" ]; then
    if backup_desktop_file "$APP_PATH" >/dev/null; then
        echo "📦 Backup saved."
    else
        echo "⚠️  Backup failed; aborting to avoid unrecoverable change." >&2
        exit 1
    fi
fi

if [ "$APP_PATH" != "$USER_APP_DIR/$SELECTED_APP" ]; then
    tmp=$(mktemp "$USER_APP_DIR/.kappicon-desktop-XXXXXX") || exit 1
    if ! cp -a -- "$APP_PATH" "$tmp"; then
        rm -f -- "$tmp"
        echo "❌ Failed to copy desktop entry to user applications."
        exit 1
    fi
    chmod 644 "$tmp" 2>/dev/null || true
    if ! atomic_replace "$tmp" "$USER_APP_DIR/$SELECTED_APP"; then
        rm -f -- "$tmp"
        echo "❌ Failed to install user desktop entry."
        exit 1
    fi
fi

if ! set_desktop_icon "$USER_APP_DIR/$SELECTED_APP" "$ICON_VALUE"; then
    echo "❌ Failed to update Icon= in $SELECTED_APP"
    exit 1
fi

echo "🎉 Success! Custom icon fully assigned to $SELECTED_APP"
echo "   Icon= $ICON_VALUE  (user hicolor)"
do_refresh
